# Kopiere diese Datei nach .env und passe die Werte an:
#   cp .env.example .env

SECRET_KEY=dev-secret-change-in-prod

# Postgres (lokale Entwicklung: DB läuft via docker-compose)
DB_HOST=localhost
POSTGRES_DB=jukebox
POSTGRES_USER=jukebox
POSTGRES_PASSWORD=jukebox
DB_PORT=5432

# Flask-Umgebung: "development" (kein HTTPS-Cookie) oder "production"
FLASK_ENV=development
